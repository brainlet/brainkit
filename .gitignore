.DS_Store
.env

# Node.js build dependencies (installed by `make deps`)
**/node_modules/**

# Build dependencies (downloaded by setup scripts, not committed)
internal/embed/compiler/deps/


# Go binary output directory — `make brainkit` + `make examples`
# land every compiled Go binary under /bin/. Covers wasmgen,
# example binaries, and the brainkit CLI.
/bin/

# wasmgen binary (legacy location — new builds go to /bin/)
/wasmgen

decisions/
internal/docs/*

.s*
.c*
.omc

playground

bin/**.go binary

# Runtime state produced by examples / ad-hoc runs
/nats-data/
/kit.db
/audit.db
/data/
/examples/*/data/

# Stray root-level binaries from pre-/bin/ builds — keep these
# ignored so developers upgrading from older checkouts don't
# accidentally commit them.
/agent-forge
/agent-spawner
/ai-chat
/cross-kit
/hello-embedded
/hello-server
/multi-kit
/observability
/gateway-routes
/go-tools
/harness-lite
/mcp
/plugin-host
/schedules
/secrets
/storage-vectors
/streaming
/workflows

# plugin-author has its own go.mod — stray legacy binary next to
# its source, new builds land in /bin/.
/examples/plugin-author/plugin-author

# Bench artifact produced by `make bench-save`; baseline.json is the
# committed reference.
/test/bench/latest.json
