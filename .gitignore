.DS_Store
.env

# Node.js build dependencies (installed by `make deps`)
**/node_modules/**

# Build dependencies (downloaded by setup scripts, not committed)
internal/embed/compiler/deps/


# Go binary output directory — `make brainkit` + `make examples`
# land every compiled Go binary under /bin/. Covers wasmgen,
# example binaries, and the brainkit CLI.
/bin/

# wasmgen binary (legacy location — new builds go to /bin/)
/wasmgen

decisions/
internal/docs/*

.s*
.c*
.omc

playground

bin/**.go binary

# Runtime state produced by examples / ad-hoc runs
/nats-data/
/kit.db
/audit.db
/data/
/examples/*/data/

# Stray root-level binaries from pre-/bin/ builds — keep these
# ignored so developers upgrading from older checkouts don't
# accidentally commit them.
/agent-forge
/agent-spawner
/ai-chat
/cross-kit
/hello-embedded
/hello-server
/multi-kit
/observability
/gateway-routes
/go-tools
/harness-lite
/mcp
/package-workflow
/plugin-host
/schedules
/secrets
/storage-vectors
/streaming
/workflows
/working-memory
/workspace-agent
/guardrails
/rag-pipeline
/evals
/custom-scorer
/hitl-tool-approval
/hitl-workflow
/agent-stream
/voice-agent
/voice-realtime

# Persistent scaffolds produced by examples that demonstrate the
# on-disk package lifecycle. These live where the example points,
# but ignore the default paths so a developer can iterate without
# polluting git status.
/forged-agents/
/package-workflow-demo/

# plugin-author has its own go.mod — stray legacy binary next to
# its source, new builds land in /bin/.
/examples/plugin-author/plugin-author

# Bench artifact produced by `make bench-save`; baseline.json is the
# committed reference.
/test/bench/latest.json

# Audio captured by example runs — the whole directory, not
# just the .mp3 payloads, so the dir itself doesn't show up as
# untracked on the first `go run` of each example.
/voice-agent-out/
/voice-broadcast-out/
/voice-realtime-out/
/examples/*/voice-agent-out/
/examples/*/voice-broadcast-out/
/examples/*/voice-realtime-out/

# Stray binaries produced when someone runs `go build ./examples/<x>`
# from the repo root without `-o bin/<x>`. `make examples` puts
# them in /bin/ (already gitignored above); anything that leaks
# out here should never land in a commit.
/evals
/rag-pipeline
/voice-agent
/voice-broadcast
/voice-chat
/voice-realtime
/workspace-agent
/working-memory
/hitl-tool-approval
/hitl-workflow
/agent-stream
/custom-scorer
/guardrails
/ai-chat
/cross-kit
/gateway-routes
/go-tools
/harness-lite
/hello-embedded
/hello-server
/mcp
/multi-kit
/observability
/package-workflow
/plugin-host
/schedules
/secrets
/storage-vectors
/streaming
/workflows
/agent-forge
/agent-spawner
